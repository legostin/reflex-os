{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "reflex-os",
  "version": "0.1.0",
  "identifier": "com.reflex.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Reflex",
        "width": 960,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "visible": false,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "quick",
        "url": "index.html?window=quick",
        "title": "Reflex Quick",
        "width": 720,
        "height": 140,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../sidecars/reflex-browser-server": "sidecars/reflex-browser-server"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
