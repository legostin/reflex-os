{
  "id": "system-research-capture",
  "name": "System · Research Capture",
  "icon": "RC",
  "description": "Capture browser pages into project memory, summarize them with an agent, and turn research into topics.",
  "entry": "index.html",
  "permissions": [
    "storage.get",
    "storage.set",
    "projects.read:*",
    "memory.global.write",
    "memory.project:*",
    "browser.read",
    "browser.control",
    "notify.show"
  ],
  "kind": "panel",
  "created_at_ms": 1,
  "schedules": [
    {
      "id": "research-review",
      "name": "Research review reminder",
      "cron": "0 0 17 * * 5",
      "enabled": false,
      "catch_up": "once",
      "steps": [
        {
          "method": "notify.show",
          "params": {
            "title": "Research Review",
            "body": "Open Research Capture and convert saved pages into project notes."
          }
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "research-captures",
      "name": "Research captures",
      "description": "Return saved browser research captures.",
      "public": true,
      "steps": [
        {
          "method": "storage.get",
          "params": {
            "key": "captures"
          }
        }
      ]
    }
  ],
  "widgets": [
    {
      "id": "research-capture",
      "name": "Research Capture",
      "entry": "index.html",
      "size": "large",
      "description": "Browser page capture, summary, and memory handoff."
    }
  ]
}
