{
  "id": "system-project-cockpit",
  "name": "System · Project Cockpit",
  "icon": "PC",
  "description": "A practical project home screen with topics, memory, schedules, files, and linked utility context.",
  "entry": "index.html",
  "permissions": [
    "storage.get",
    "storage.set",
    "projects.read:*",
    "topics.read:*",
    "project.files.read:*",
    "memory.project:*",
    "scheduler.read:*",
    "notify.show"
  ],
  "kind": "panel",
  "created_at_ms": 1,
  "schedules": [
    {
      "id": "cockpit-refresh-marker",
      "name": "Project Cockpit refresh marker",
      "cron": "0 0 8 * * *",
      "enabled": false,
      "catch_up": "once",
      "steps": [
        {
          "method": "storage.set",
          "params": {
            "key": "lastAutomatedRefresh",
            "value": {
              "source": "schedule",
              "note": "Refresh Project Cockpit to inspect current project state."
            }
          }
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "project-cockpit-settings",
      "name": "Project Cockpit settings",
      "description": "Return saved cockpit preferences.",
      "public": true,
      "steps": [
        {
          "method": "storage.get",
          "params": {
            "key": "settings"
          }
        }
      ]
    }
  ],
  "widgets": [
    {
      "id": "project-cockpit",
      "name": "Project Cockpit",
      "entry": "index.html",
      "size": "large",
      "description": "Project topics, memory, schedules, files, and linked utilities."
    }
  ]
}
