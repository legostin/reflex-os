{
  "id": "system-project-file-lens",
  "name": "System · Project File Lens",
  "icon": "FL",
  "description": "Search linked project files, preview content, save bookmarks, and open project surfaces.",
  "entry": "index.html",
  "permissions": [
    "storage.get",
    "storage.set",
    "projects.read:*",
    "topics.read:*",
    "project.files.read:*",
    "clipboard.write"
  ],
  "kind": "panel",
  "created_at_ms": 1,
  "actions": [
    {
      "id": "file-lens-bookmarks",
      "name": "File Lens bookmarks",
      "description": "Return saved project file bookmarks.",
      "public": true,
      "steps": [
        {
          "method": "storage.get",
          "params": {
            "key": "bookmarks"
          }
        }
      ]
    }
  ],
  "widgets": [
    {
      "id": "file-lens",
      "name": "File Lens",
      "entry": "index.html",
      "size": "large",
      "description": "Project search and bookmarked files."
    }
  ]
}
